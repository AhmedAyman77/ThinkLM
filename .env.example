# Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Embedding model
EMBEDDING_MODEL_ID=gemini-embedding-exp-03-07
EMBEDDING_MODEL_SIZE=3072

# Supabase for Auth service
SUPABASE_URL=supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Redis
REDIS_URL=redis_url_here

# QdrantDB
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_HOST=qdrant_host_here

# service urls (internal Docker ports, only gateway is exposed)
FILE_PROCESSOR_URL=http://file_processor:8001
AGENT_SERVICE_URL=http://agent:8003
